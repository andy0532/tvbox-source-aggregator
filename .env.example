# TVBox Source Aggregator 配置

# 管理后台密码（必填）
ADMIN_TOKEN=changeme

# 多用户登录（可选，JSON 格式用户列表，与 ADMIN_TOKEN 配合使用）
# 登录时用户输入用户名+密码，验证通过后获得 ADMIN_TOKEN 作为 Bearer token
USERS=[{"username":"admin","password":"changeme"}]

# 服务端口
PORT=5678

# 外部访问地址（Docker 部署时必填，用于 JAR 代理地址改写）
# 设为宿主机的实际 IP + 映射端口，例如：
# BASE_URL=http://192.168.1.100:5678
BASE_URL=

# 定时聚合（Cron 表达式，UTC 时区）
# 默认 UTC 5:00 = 北京时间 13:00
CRON_SCHEDULE=0 5 * * *

# 刷新接口独立 Token（可选，留空则使用 ADMIN_TOKEN）
REFRESH_TOKEN=

# 超时配置（毫秒）
SPEED_TIMEOUT_MS=5000   # 源地址延迟阈值
SITE_TIMEOUT_MS=3000    # 站点 API 测速超时
FETCH_TIMEOUT_MS=5000   # 抓取配置 JSON 超时

# 数据目录（默认 ./data）
DATA_DIR=
